rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /kader/{kaderId} {
      allow read, write: if true;
    }
    match /news/{newsId} {
      allow read, write: if true;
    }
    match /dpc/{dpcId} {
      allow read, write: if true;
    }
    match /messages/{messageId} {
      allow read, write: if true;
    }
    match /settings/{settingsId} {
      allow read, write: if true;
    }
  }
}
